/* 全局样式 */
page {
  background: linear-gradient(135deg, #f8fbff 0%, #eef6ff 50%, #f7fafc 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #1e293b;
  min-height: 100vh;
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 16px;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  border: 1px solid #e2e8f0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #2563eb, #0ea5e9);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx 0;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 加载动画 */
.spinner {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 24rpx 0;
}
