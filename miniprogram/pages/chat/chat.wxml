<!-- 智能问答页面 -->
<view class="page">
  <!-- 标题栏 -->
  <view class="header">
    <text class="header-icon">🧠</text>
    <text class="header-title">智能医学问答</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="msg-list" scroll-y scroll-into-view="msg-{{messages.length - 1}}">
    <view wx:if="{{messages.length === 0}}" class="empty-hint">
      <text class="empty-icon">💬</text>
      <text class="empty-text">输入你的医学问题，开始对话</text>
    </view>

    <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}"
          class="msg-item {{item.role === 'user' ? 'msg-user' : 'msg-assistant'}}">
      <!-- 角色标签 -->
      <text class="msg-role">{{item.role === 'user' ? '👤' : '🤖'}}</text>

      <!-- 内容 -->
      <view class="msg-bubble {{item.role}}">
        <!-- CoT 推理过程 -->
        <view wx:if="{{item.cot && item.role === 'assistant'}}" class="cot-section">
          <view class="cot-header" bindtap="toggleCot" data-index="{{index}}">
            <text>🔍 推理过程</text>
            <text class="cot-arrow">{{item.cotExpanded ? '▼' : '▶'}}</text>
          </view>
          <view wx:if="{{item.cotExpanded}}" class="cot-body">
            <text>{{item.cot}}</text>
          </view>
        </view>

        <!-- 最终答案 -->
        <view class="answer-section">
          <text wx:if="{{item.role === 'assistant' && item.cot}}" class="answer-label">📋 最终答案：</text>
          <text class="msg-text">{{item.content}}</text>
        </view>
      </view>
    </view>

    <!-- 加载指示器 -->
    <view wx:if="{{loading}}" class="spinner">
      <text>AI 思考中...</text>
    </view>
  </scroll-view>

  <!-- 输入区域 -->
  <view class="input-bar">
    <input class="msg-input"
           placeholder="请输入你的医学问题..."
           value="{{inputText}}"
           bindinput="onInput"
           bindconfirm="onSend"
           confirm-type="send"
           disabled="{{loading}}"
           auto-focus />
    <button class="send-btn" bindtap="onSend" disabled="{{loading || !inputText}}">
      发送
    </button>
  </view>
</view>
