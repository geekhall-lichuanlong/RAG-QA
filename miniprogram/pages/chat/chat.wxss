/* 智能问答页面样式 */
.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(135deg, #f8fbff 0%, #eef6ff 50%);
}

/* 标题 */
.header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #ffffff;
  border-bottom: 1px solid #e2e8f0;
}

.header-icon { font-size: 44rpx; margin-right: 12rpx; }

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 24rpx;
  overflow-y: auto;
}

.empty-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { color: #94a3b8; font-size: 28rpx; }

/* 消息项 */
.msg-item {
  display: flex;
  margin-bottom: 32rpx;
}

.msg-user { flex-direction: row-reverse; }
.msg-assistant { flex-direction: row; }

.msg-role {
  font-size: 40rpx;
  margin: 0 12rpx;
  flex-shrink: 0;
}

.msg-bubble {
  max-width: 80%;
  border-radius: 20rpx;
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.msg-bubble.user {
  background: linear-gradient(135deg, #2563eb, #0ea5e9);
  color: #ffffff;
  border-bottom-right-radius: 4rpx;
}

.msg-bubble.assistant {
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-bottom-left-radius: 4rpx;
}

/* CoT 区域 */
.cot-section {
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1px dashed #cbd5e1;
}

.cot-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #64748b;
  padding: 8rpx 0;
}

.cot-arrow { font-size: 20rpx; }

.cot-body {
  margin-top: 12rpx;
  padding: 16rpx;
  background: #f8fafc;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.7;
}

.answer-label {
  font-weight: 600;
  color: #2563eb;
  font-size: 28rpx;
}

.msg-text {
  word-break: break-all;
}

/* 加载 */
.spinner {
  text-align: center;
  padding: 32rpx;
  color: #94a3b8;
  font-size: 24rpx;
}

/* 输入栏 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: env(safe-area-inset-bottom);
  background: #ffffff;
  border-top: 1px solid #e2e8f0;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  border-radius: 36rpx;
  background: #f1f5f9;
  padding: 0 28rpx;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.send-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #2563eb, #0ea5e9);
  color: #ffffff;
  border: none;
  border-radius: 36rpx;
  padding: 0;
}

.send-btn[disabled] {
  background: #cbd5e1;
  color: #94a3b8;
}
