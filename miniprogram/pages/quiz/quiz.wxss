/* 答题练习页面 */
.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(135deg, #f8fbff 0%, #eef6ff 50%);
}

/* 进度条 */
.progress-bar {
  height: 12rpx;
  background: #e2e8f0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #2563eb, #0ea5e9);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 24rpx;
}

/* 题目卡片 */
.question-card {
  margin: 0 0 24rpx;
}

.q-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 16rpx;
}

.q-text {
  font-size: 32rpx;
  line-height: 1.7;
  color: #1e293b;
  display: block;
  margin-bottom: 32rpx;
}

/* 选项 */
.options-group { width: 100%; }

.option-item {
  margin-bottom: 16rpx;
  padding: 20rpx 24rpx;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 14rpx;
  transition: 0.2s;
}

.option-item:active {
  border-color: #3b82f6;
  background: #eff6ff;
}

.option-item.correct {
  border-color: #22c55e;
  background: #f0fdf4;
}

.option-item.wrong {
  border-color: #ef4444;
  background: #fef2f2;
}

.option-label {
  display: flex;
  align-items: flex-start;
}

.option-letter {
  font-weight: 700;
  color: #2563eb;
  margin: 0 12rpx;
  min-width: 40rpx;
}

.option-text {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.5;
  flex: 1;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 24rpx;
  width: 100%;
}

.submit-btn[disabled] {
  background: #cbd5e1;
  color: #94a3b8;
}

/* 结果 */
.result-area { margin-top: 24rpx; }

.result-success, .result-fail {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.result-success {
  background: #f0fdf4;
  border: 1px solid #86efac;
  color: #166534;
}

.result-fail {
  background: #fef2f2;
  border: 1px solid #fca5a5;
  color: #991b1b;
}

.result-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* AI 解析 */
.btn-explain {
  margin-top: 24rpx;
  width: 100%;
  background: #ffffff;
  border: 1px solid #2563eb;
  color: #2563eb;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 0;
}

.explanation-box {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 16px;
}

.exp-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #2563eb;
  margin-bottom: 16rpx;
}

.exp-body {
  font-size: 26rpx;
  line-height: 1.8;
  color: #475569;
}

/* 导航 */
.nav-bar {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.nav-btn {
  flex: 1;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
}

.nav-btn[disabled] {
  opacity: 0.4;
}
